module physics;

fn aabb_check(ax: i32, ay: i32, aw: i32, ah: i32, bx: i32, by: i32, bw: i32, bh: i32) -> i32 {
    if (ax + aw < bx || bx + bw < ax || ay + ah < by || by + bh < ay) {
        return 0;
    }
    return 1;
}

fn resolve_collision_test(px: i32, py: i32, pw: i32, ph: i32, cx: i32, cy: i32, cw: i32, ch: i32) -> i32 {
    if (aabb_check(px, py, pw, ph, cx, cy, cw, ch) == 0) {
        return 0;
    }
    return 1;
}
