{
  "project": "platformer-game",
  "version": "0.1.0",
  "author": "Novus Community",
  "description": "A fast-paced 2D platformer game built with Novus",
  "main": "main.nov",
  "target": "linux/amd64",
  "libraries": [
    {
      "name": "framebuffer",
      "path": "./lib/framebuffer",
