module framebuffer;

let fb_fd: i32 = -1;

fn fb_open() -> i32 { return -1; }
fn fb_close() -> void {}
fn fb_get_width() -> i32 { return 800; }
fn fb_get_height() -> i32 { return 600; }
fn fb_set_pixel(x: i32, y: i32, color: i32) -> void {}
fn fb_get_pixel(x: i32, y: i32) -> i32 { return 0; }
fn fb_draw_rect(x: i32, y: i32, w: i32, h: i32, color: i32) -> void {}
fn fb_clear(color: i32) -> void {}
fn fb_flush() -> i32 { return 0; }
